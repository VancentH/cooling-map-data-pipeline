# Copy this file to .env and fill in your values.
# Usage: source .env && bash scripts/fetch.sh

# Your GitHub repository URL — used in the Overpass API User-Agent header.
# This identifies your fork to the Overpass API operators.
# Required: the script will refuse to run if this is not set.
REPO_URL=https://github.com/<your-GitHub-username>/cooling-map-data-pipeline
